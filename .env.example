# InvestGlass onboarding API
INVESTGLASS_API_URL=https://your-tenant.investglass.com/api/v1
INVESTGLASS_API_KEY=

# Email (SMTP) for verification codes
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@framont.com

# SMS (Twilio) for verification codes
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Admin panel access
ADMIN_TOKEN=

# CORS: the front end origin allowed to call these functions
ALLOWED_ORIGIN=*
